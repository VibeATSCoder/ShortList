# Shortlist ATS · cPanel production variables
# Copy these values into cPanel > Setup Node.js App > Environment Variables.
# Never upload this file after adding secrets.

NODE_ENV=production
APP_URL=https://ats.mehdisharifi.com
DEPLOYMENT_ID=replace-with-release-commit-sha

# Next.js self-hosting key. Generate: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Authentication/session material. Generate: openssl rand -base64 48
SESSION_SECRET=
# Signs live screening results before they can enter the canonical ATS database.
# Generate independently: openssl rand -base64 48
ASSESSMENT_SEAL_SECRET=

# cPanel MySQL/MariaDB. Use 127.0.0.1 so the database is never public.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=CPANELPREFIX_shortlist
DB_USER=CPANELPREFIX_atsapp
DB_PASSWORD=
DB_POOL_SIZE=4
DB_SSL=false

# Bootstrap only. Remove BOOTSTRAP_ADMIN_PASSWORD immediately after
# `npm run db:bootstrap` succeeds.
BOOTSTRAP_ADMIN_EMAIL=reviews@ats.mehdisharifi.com
BOOTSTRAP_ADMIN_NAME=Mehdi Sharifi
BOOTSTRAP_ORGANIZATION_NAME=Shortlist Studio
BOOTSTRAP_ADMIN_PASSWORD=

# cPanel SMTP. The supplied account uses implicit TLS on port 465. The supplied
# `ats.mehdisharifi.com` host cannot carry SMTP while Cloudflare-proxied, so use
# this dedicated DNS-only name after AutoSSL covers it (or Connect Devices' exact host).
SMTP_HOST=mail.ats.mehdisharifi.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=reviews@ats.mehdisharifi.com
SMTP_PASSWORD=
EMAIL_FROM="Shortlist Reviews <reviews@ats.mehdisharifi.com>"
EMAIL_REPLY_TO=reviews@ats.mehdisharifi.com
HR_NOTIFICATION_EMAIL=mrtensor8@gmail.com
REVIEW_ALLOWED_RECIPIENTS=mrtensor8@gmail.com,lexapro8585@gmail.com

# Signed temporary reviewer links. Generate: openssl rand -base64 48
REVIEW_LINK_SECRET=
CRON_SECRET=

# Private uploads live outside public_html and are encrypted before writing.
PRIVATE_UPLOAD_DIR=/home/CPANEL_USER/apps/shortlist/shared/uploads
REVIEW_STORAGE_DIR=/home/CPANEL_USER/apps/shortlist/shared/reviews
# Exactly 32 random bytes encoded as base64. Rotation requires a controlled
# decrypt/re-encrypt migration before changing the version.
FILE_ENCRYPTION_KEY=
FILE_ENCRYPTION_KEY_VERSION=1

# AI screening. Add only after the MySQL-backed spend guard/worker is enabled.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
RATE_LIMIT_KEY_SALT=
SAFETY_IDENTIFIER_SALT=

# Keep blank on cPanel. This is only for the legacy Vercel demo review store.
BLOB_READ_WRITE_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
