# Server-only. Never prefix this key with NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_BASE_URL=
# Alternative explicit OpenRouter secret; takes precedence over OPENAI_API_KEY.
OPENROUTER_API_KEY=

# Current frontier alias. Pin a dated snapshot after your bilingual eval set is stable.
OPENAI_MODEL=gpt-5.6
SHOWCASE_CANDIDATE_EMAIL=

# Optional on cPanel because configured MySQL provides the distributed limiter.
# Vercel/serverless production still uses Upstash; paid calls fail closed when
# neither durable backend is available.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Independent random values used only to pseudonymize rate-limit and provider
# safety identifiers. Generate each with at least 32 random bytes in production.
RATE_LIMIT_KEY_SALT=
SAFETY_IDENTIFIER_SALT=

# Free Vercel Hobby collaboration layer. Connect a PRIVATE Vercel Blob store
# to the project so Vercel provides BLOB_READ_WRITE_TOKEN automatically.
BLOB_READ_WRITE_TOKEN=

# At least 32 random bytes. Signs expiring team-review URLs.
REVIEW_LINK_SECRET=

# Used by Vercel Cron as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# Canonical production origin used inside email links.
APP_URL=https://shortlist-ai-proof.vercel.app

# Optional cPanel SMTP delivery. Review links work without these values.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="Shortlist <reviews@example.com>"
EMAIL_REPLY_TO=
HR_NOTIFICATION_EMAIL=

# Comma-separated exact allowlist. The public application refuses to send to
# any address outside this list, preventing it from becoming an email relay.
REVIEW_ALLOWED_RECIPIENTS=

# Optional cPanel MySQL recruiter workspace. When these are absent, /workspace
# runs as an interactive read-only portfolio demo.
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_POOL_SIZE=4
DB_SSL=false

# At least 32 random bytes. Auth is enabled only with both MySQL and this value.
SESSION_SECRET=
ASSESSMENT_SEAL_SECRET=

# Optional encrypted private-file directory for the cPanel deployment.
PRIVATE_UPLOAD_DIR=
REVIEW_STORAGE_DIR=
FILE_ENCRYPTION_KEY=
FILE_ENCRYPTION_KEY_VERSION=1
